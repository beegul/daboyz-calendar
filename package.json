{
  "name": "daboyz-availability-calendar",
  "private": true,
  "type": "module",
  "version": "1.0.0",
  "description": "Shared availability calendar for friend groups with React + Azure serverless",
  "scripts": {
    "dev": "concurrently \"vite dev\" \"func start\" \"swa start --api-location ./api\"",
